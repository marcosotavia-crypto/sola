{
  "entities": {
    "FootwearItem": {
      "title": "Footwear Item",
      "description": "A single pair of footwear in production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "model": { "type": "string" },
        "color": { "type": "string" },
        "size": { "type": "string" },
        "quantity": { "type": "number" },
        "barcode": { "type": "string" },
        "status": { 
          "type": "string",
          "enum": ["Pendente", "Produzido", "Cancelado"]
        },
        "producedBy": { "type": "string" },
        "orderDate": { "type": "number" },
        "deadline": { "type": "number" },
        "programmingId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["orderNumber", "model", "color", "size", "barcode", "status", "createdAt", "updatedAt", "quantity", "orderDate", "deadline"]
    },
    "Operator": {
      "title": "Operator",
      "description": "A factory operator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "createdAt"]
    },
    "Programming": {
      "title": "Programming",
      "description": "A production programming grouping multiple orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "orderNumbers": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["Ativa", "Concluída", "Arquivada"]
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "orderNumbers", "status", "createdAt", "updatedAt"]
    },
    "Material": {
      "title": "Material",
      "description": "Raw material used in production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "unit", "createdAt"]
    },
    "ModelConsumption": {
      "title": "Model Consumption",
      "description": "Consumption rate of a material for a specific model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "modelName": { "type": "string" },
        "materialId": { "type": "string" },
        "size": { "type": "string" },
        "consumptionPerPair": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["modelName", "materialId", "consumptionPerPair", "createdAt"]
    }
  },
  "firestore": {
    "/productionItems/{itemId}": {
      "schema": "FootwearItem",
      "description": "Collection of all footwear items in production"
    },
    "/operators/{operatorId}": {
      "schema": "Operator",
      "description": "Collection of factory operators"
    },
    "/programmings/{programmingId}": {
      "schema": "Programming",
      "description": "Collection of production programmings"
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Collection of raw materials"
    },
    "/modelConsumptions/{consumptionId}": {
      "schema": "ModelConsumption",
      "description": "Collection of model consumption rates"
    }
  }
}
