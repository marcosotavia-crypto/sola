rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "Marcosotavia@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidStatus(status) {
      return status in ['Pendente', 'Produzido', 'Cancelado'];
    }

    function isValidItem(data) {
      return data.keys().hasAll(['orderNumber', 'model', 'color', 'size', 'barcode', 'status', 'createdAt', 'updatedAt', 'quantity', 'orderDate', 'deadline']) &&
             data.orderNumber is string && data.orderNumber.size() < 50 &&
             data.model is string && data.model.size() < 100 &&
             data.color is string && data.color.size() < 50 &&
             data.size is string && data.size.size() < 10 &&
             data.barcode is string && data.barcode.size() < 100 &&
             data.quantity is number && data.quantity > 0 &&
             isValidStatus(data.status) &&
             data.orderDate is number &&
             data.deadline is number &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (!('programmingId' in data) || data.programmingId is string) &&
             (!('producedBy' in data) || (data.producedBy is string && data.producedBy.size() < 100));
    }

    function isValidOperator(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is number;
    }

    function isValidProgramming(data) {
      return data.keys().hasAll(['name', 'orderNumbers', 'status', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.orderNumbers is list && data.orderNumbers.size() > 0 &&
             data.status in ['Ativa', 'Concluída', 'Arquivada'] &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['name', 'unit', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 20 &&
             data.createdAt is number;
    }

    function isValidModelConsumption(data) {
      return data.keys().hasAll(['modelName', 'materialId', 'consumptionPerPair', 'createdAt']) &&
             data.modelName is string && data.modelName.size() > 0 && data.modelName.size() < 100 &&
             data.materialId is string &&
             data.consumptionPerPair is number && data.consumptionPerPair >= 0 &&
             data.createdAt is number &&
             (!('size' in data) || (data.size is string && data.size.size() < 10));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /productionItems/{itemId} {
      allow read: if true;
      allow create: if isValidItem(request.resource.data);
      allow update: if isValidItem(request.resource.data) &&
                    request.resource.data.barcode == resource.data.barcode &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if true;
    }

    match /operators/{operatorId} {
      allow read: if true;
      allow create: if isValidOperator(request.resource.data);
      allow update: if isValidOperator(request.resource.data);
      allow delete: if true;
    }

    match /programmings/{programmingId} {
      allow read: if true;
      allow create: if isValidProgramming(request.resource.data);
      allow update: if isValidProgramming(request.resource.data);
      allow delete: if true;
    }

    match /materials/{materialId} {
      allow read: if true;
      allow create: if isValidMaterial(request.resource.data);
      allow update: if isValidMaterial(request.resource.data);
      allow delete: if true;
    }

    match /modelConsumptions/{consumptionId} {
      allow read: if true;
      allow create: if isValidModelConsumption(request.resource.data);
      allow update: if isValidModelConsumption(request.resource.data);
      allow delete: if true;
    }
  }
}
